NODE_ENV=development
# Optional — defaults to 3000; leave unset if a tool (preview, launchd plist)
# supplies PORT through the environment
#PORT=3000

# Email notifications (optional)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=
NOTIFY_EMAIL=your-email@gmail.com
NOTIFY_FREQUENCY=daily

# Database
DB_PATH=./data/jobs.db

# Job search (customize for your role and locations)
JOB_TITLE=Software Engineer
SEARCH_LOCATIONS=remote,San Francisco CA,New York NY
